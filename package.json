{
  "name": "tavern",
  "version": "0.0.0",
  "private": true,
  "description": "Tavern — self-hosted Discord-shaped community app for gaming groups, tabletop RPGs, and board gamers",
  "license": "MIT",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./apps/*\" --filter \"./packages/*\" build",
    "ensure-env": "node scripts/ensure-env.mjs",
    "predev": "pnpm ensure-env",
    "dev": "pnpm -r --parallel --filter \"./apps/*\" dev",
    "predev:api": "pnpm ensure-env",
    "dev:api": "pnpm --filter @tavern/api dev",
    "predev:web": "pnpm ensure-env",
    "dev:web": "pnpm --filter @tavern/web dev",
    "predev:worker": "pnpm ensure-env",
    "dev:worker": "pnpm --filter @tavern/worker dev",
    "test": "pnpm -r test",
    "test:integration": "pnpm --filter @tavern/api test:integration",
    "test:e2e": "pnpm --filter @tavern/e2e test:e2e",
    "walkthrough": "pnpm --filter @tavern/e2e test:walkthrough && pnpm --filter @tavern/e2e walkthrough:assemble",
    "walkthrough:headed": "pnpm --filter @tavern/e2e test:walkthrough:headed && pnpm --filter @tavern/e2e walkthrough:assemble",
    "walkthrough:assemble": "pnpm --filter @tavern/e2e walkthrough:assemble",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @tavern/db generate",
    "db:migrate": "pnpm --filter @tavern/db migrate",
    "db:seed": "pnpm --filter @tavern/db seed",
    "db:reset": "pnpm --filter @tavern/db reset",
    "garage:config": "node scripts/garage-config.mjs",
    "docker:up": "node scripts/garage-config.mjs && docker compose -f infra/docker/docker-compose.yml up -d",
    "docker:up:all": "node scripts/garage-config.mjs && docker compose -f infra/docker/docker-compose.yml --profile livekit up -d",
    "docker:up:full": "node scripts/garage-config.mjs && docker compose -f infra/docker/docker-compose.yml --profile apps --profile livekit up -d --build",
    "docker:build": "docker compose -f infra/docker/docker-compose.yml --profile apps build",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml --profile apps --profile livekit down",
    "docker:logs": "docker compose -f infra/docker/docker-compose.yml --profile apps --profile livekit logs -f",
    "garage:bootstrap": "node scripts/garage-bootstrap.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "@tanstack/history": "1.161.6"
    },
    "auditConfig": {
      "ignoreGhsas": ["GHSA-rmmr-r34h-pfm5"]
    }
  }
}
