{
  "name": "@tavern/e2e",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node -e \"console.log('e2e tests are opt-in. Start the dev stack and run: pnpm --filter @tavern/e2e test:e2e')\"",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "install-browsers": "playwright install --with-deps chromium",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
  }
}
