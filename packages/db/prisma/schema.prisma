enum NoteVisibility {
  public_to_party
  gm_only
}

model CampaignNote {
  id          String         @id
  campaignId  String
  serverId    String
  authorId    String
  title       String
  body        String
  visibility  NoteVisibility @default(public_to_party)
  pinned      Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  author   User     @relation("NoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([campaignId, pinned])
}

enum HandoutVisibility {
  public_to_party
  gm_only
  specific_players
}

model Handout {
  id           String              @id
  campaignId   String
  serverId     String
  authorId     String
  title        String
  body         String              @default("")
  visibility   HandoutVisibility   @default(public_to_party)
  attachmentIds String[]           @default([])
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  campaign     Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  author       User                 @relation("HandoutAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  visibleUsers HandoutVisibleUser[]

