// ============================================================================
// MODERATION / SAFETY  (Phase 2)
// ============================================================================

enum ReportTargetType {
  message
  attachment
  profile
  emoji
  campaign_note
  handout
  voice_message
}

enum ReportCategory {
  suspected_child_exploitation_or_csam
  non_consensual_intimate_material
  credible_threat_or_violent_coordination
  stalking_swatting_or_targeted_harassment
  doxxing_or_private_information
  malware_phishing_or_credential_theft
  illegal_marketplace_or_trafficking
  fraud_or_scam
  spam_or_raid
  policy_evasion
  other_serious_abuse
}

enum ReportStatus {
  open
  in_review
  resolved
  dismissed
  escalated
}

model Report {
  id              String           @id
  serverId        String?
  reporterId      String
  targetType      ReportTargetType
  targetId        String
  category        ReportCategory
  notes           String?
  status          ReportStatus     @default(open)
  resolvedById    String?
  resolutionNotes String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  server   Server? @relation(fields: [serverId], references: [id], onDelete: SetNull)
  reporter User    @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([serverId, status])
  @@index([targetType, targetId])
}

model ModerationAction {
  id          String   @id
  reportId    String?
  moderatorId String
  serverId    String?
  targetType  String
  targetId    String
  action      String
  notes       String?
  metadata    Json?
  createdAt   DateTime @default(now())

  moderator User @relation("Moderator", fields: [moderatorId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
  @@index([reportId])
  @@index([serverId])
}

model AuditLogEntry {
  id          String   @id
  serverId    String?
  actorId     String?
  action      String
  targetType  String?
  targetId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  server  Server? @relation(fields: [serverId], references: [id], onDelete: Cascade)
  actor   User?   @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([serverId, createdAt])
  @@index([action])
}

model SafetyPolicy {
  serverId               String   @id
  sfwOnly                Boolean  @default(false)
  allowNsfwChannels      Boolean  @default(true)
  spoilerTagsEnabled     Boolean  @default(true)
  profanityFilter        String   @default("off")
  uploadDomainAllowlist  String[] @default([])
  uploadDomainBlocklist  String[] @default([])
  blockExecutableUploads Boolean  @default(true)
  blockArchiveUploads    Boolean  @default(true)
  stripImageMetadata     Boolean  @default(true)
  updatedAt              DateTime @updatedAt

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
}

// ============================================================================
// DIRECT MESSAGES  (Phase 6)
// ============================================================================

/// Discriminator on `DmChannel`. `direct` is enforced to have exactly 2
/// members (one of whom is the calling user) at the application layer;
/// `group` has 3+ members.
enum DmChannelKind {
  direct
  group
}

/// A DM channel: 1:1 or small group. No server. Reuses `Message`,
/// `Attachment`, `MessageReaction`, and `DiceRoll` via nullable
/// `serverId`/`channelId` + `dmChannelId` columns on those tables.
model DmChannel {
  id            String        @id
  kind          DmChannelKind
  name          String?
  createdById   String?
  createdAt     DateTime      @default(now())
  /// Used for sort order in the DM list. Updated on every new message.
  lastMessageAt DateTime?
  /// Deterministic key for 1:1 DMs — sorted `userIdA:userIdB` of the two
  /// members. Set only for `kind = 'direct'` rows; null for group DMs.
  /// PostgreSQL treats NULLs as distinct in UNIQUE constraints, so multiple
  /// group DMs are fine; direct DMs are deduplicated by this key so
  /// concurrent calls to `findOrCreateDirectDm` can't produce duplicates.
  pairKey       String?       @unique

  createdBy User?             @relation("DmChannelCreator", fields: [createdById], references: [id], onDelete: SetNull)
  members   DmChannelMember[]
  messages  Message[]         @relation("DmChannelMessages")
  diceRolls DiceRoll[]        @relation("DmChannelDiceRolls")
  // Phase 1.3 — direct mentions in DM messages
  mentions  UserMention[]

  @@index([lastMessageAt])
}

model DmChannelMember {
  dmChannelId String
  userId      String
  joinedAt    DateTime  @default(now())
  /// Watermark for unread-count UI. Optional; null means "never seen".
  lastReadAt  DateTime?

  channel DmChannel @relation(fields: [dmChannelId], references: [id], onDelete: Cascade)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([dmChannelId, userId])
  @@index([userId])
}

// ============================================================================
// NOTIFICATION PREFERENCES  (Phase 6)
// ============================================================================

/// User-global notification preferences. 1:1 with `User`; created lazily
/// on first read.
model UserNotificationPreference {
  userId                  String   @id
  soundEnabled            Boolean  @default(true)
  /// 0..100, applied as the master gain on the synthesized notification sounds.
  volume                  Int      @default(70)
  /// When true (default), suppress chat sounds while the user is in a voice room.
  chatSoundsWhileInVoice  Boolean  @default(false)
  /// When true (default), chat sounds only fire while the relevant tavern's
  /// channel is NOT currently focused. When false, sounds fire even while
  /// looking right at the channel — useful for users who keep the tab
  /// muted at the OS level and rely on Tavern for cues.
  playOnlyWhenUnfocused   Boolean  @default(true)
  /// When true, @mentions ignore the per-tavern mute and always sound.
  mentionsOverrideMute    Boolean  @default(true)
  /// Wave 3 #31 — snooze all notifications until this time. Null = not snoozed.
  snoozeUntil             DateTime?
  /// Wave 3 #31 — daily quiet hours. ISO time strings "HH:mm" in the user's
  /// timezone (User.timezone); null = disabled. When both are set and the
  /// current time is between them, notifications are suppressed.
  quietHoursStart         String?   @db.VarChar(5)
  quietHoursEnd           String?   @db.VarChar(5)
  /// Wave 3 #31 — when set, quiet hours only apply on these weekdays
  /// (0=Sun..6=Sat). Empty array = every day.
  quietHoursDays          Json      @default("[]")
  updatedAt               DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Per-tavern overrides for the calling member. Composite key is
/// (serverId, userId); created lazily on first PATCH.
model ServerMemberNotificationPreference {
  serverId      String
  userId        String
  /// Mute every notification sound from this tavern (messages and mentions).
  muteAll       Boolean  @default(false)
  /// Mute regular message sounds (mentions still play unless `muteMentions`).
  muteMessages  Boolean  @default(false)
  /// Mute @mention sounds for this tavern.
  muteMentions  Boolean  @default(false)
  updatedAt     DateTime @updatedAt

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([serverId, userId])
  @@index([userId])
}

// ============================================================================
// Phase-1.3 — Activity inbox & unread state
// ============================================================================

/// Per-(user, channel) read cursor + cached mention count. Advanced via
/// POST /api/channels/:id/ack as the user views messages. The frontend
/// derives the unread badge by comparing `lastReadMessageId` against the
/// channel's most recent message id (lexically sortable ULIDs).
model UserChannelReadState {
  userId             String
  channelId          String
  lastReadMessageId  String?
  lastReadAt         DateTime  @default(now())
  /// Cached count of unread mentions. Kept in sync by UserMention writes
  /// and ack calls so the inbox bell doesn't need an aggregate query.
  mentionCount       Int       @default(0)
  updatedAt          DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([userId, channelId])
  @@index([userId])
}

enum MentionKind {
  user
  role
  everyone
  here
}

/// One row per user mentioned in a message. Written by the message-create
/// route after parseMentions(). The Inbox page selects unread rows
/// (isRead=false) ordered by createdAt desc.
model UserMention {
  id        String      @id
  userId    String
  messageId String
  channelId String?
  dmChannelId String?
  kind      MentionKind
  isRead    Boolean     @default(false)
  createdAt DateTime    @default(now())

  user    User       @relation("MentionUser", fields: [userId], references: [id], onDelete: Cascade)
  message Message    @relation(fields: [messageId], references: [id], onDelete: Cascade)
  channel Channel?   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  dmChannel DmChannel? @relation(fields: [dmChannelId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([messageId])
}

// ============================================================================
// Phase-2.1 — Pinned messages
// ============================================================================

model PinnedMessage {
  /// A message is in exactly one channel and can be pinned at most once,
  /// so messageId is the natural primary key. The 1-to-1 with Message
  /// requires this @id (Prisma needs the FK to be unique).
  messageId String   @id
  channelId String
  pinnedBy  String
  pinnedAt  DateTime @default(now())
  note      String?

  channel      Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  message      Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pinnedByUser User    @relation("PinnedBy", fields: [pinnedBy], references: [id], onDelete: Cascade)

  @@index([channelId, pinnedAt])
}

// ============================================================================
// Phase-2.2 — Saved messages (personal bookmarks)
// ============================================================================

model SavedMessage {
  userId    String
  messageId String
  savedAt   DateTime @default(now())
  note      String?

  user    User    @relation("SavedByUser", fields: [userId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@id([userId, messageId])
  @@index([userId, savedAt])
}

// ============================================================================
// Phase-3.1 — Threads
// ============================================================================

model Thread {
  id              String   @id
  channelId       String
  rootMessageId   String   @unique
  title           String?
  archivedAt      DateTime?
  lastActivityAt  DateTime @default(now())
  createdAt       DateTime @default(now())
  createdBy       String

  channel     Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  rootMessage Message   @relation("ThreadRoot", fields: [rootMessageId], references: [id], onDelete: Cascade)
  creator     User      @relation("ThreadCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  messages    Message[] @relation("ThreadMessages")

  @@index([channelId, lastActivityAt])
}

// ============================================================================
// Phase-3.2 — Polls
// ============================================================================

model Poll {
  id           String    @id
  messageId    String    @unique
  question     String
  multiChoice  Boolean   @default(false)
  anonymous    Boolean   @default(false)
  closesAt     DateTime?
  closedAt     DateTime?
  createdBy    String
  createdAt    DateTime  @default(now())

  message Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  creator User         @relation("PollCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  options PollOption[]
  votes   PollVote[]
}

model PollOption {
  id       String @id
  pollId   String
  label    String
  position Int

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@index([pollId])
}

model PollVote {
  pollId    String
  optionId  String
  userId    String
  createdAt DateTime @default(now())

  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User       @relation("PollVoter", fields: [userId], references: [id], onDelete: Cascade)

  @@id([pollId, optionId, userId])
  @@index([pollId])
  @@index([userId])
}

// ============================================================================
// Phase-3.3 — Scheduled dispatch (messages + reminders)
// ============================================================================

enum DispatchKind {
  message
  reminder
}

enum DispatchStatus {
  pending
  sent
  cancelled
  failed
}

model ScheduledDispatch {
  id            String         @id
  userId        String
  kind          DispatchKind
  channelId     String?
  dmChannelId   String?
  payload       Json
  dispatchAt    DateTime
  status        DispatchStatus @default(pending)
  sentMessageId String?
  failureReason String?
  jobId         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user User @relation("DispatchOwner", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, dispatchAt])
  @@index([status, dispatchAt])
}

// ============================================================================
// Phase-4 — Initiative tracker
// ============================================================================

enum EncounterStatus {
  setup
  running
  ended
}

model InitiativeEncounter {
  id               String          @id
  channelId        String
  campaignId       String?
  createdBy        String
  status           EncounterStatus @default(setup)
  currentTurnIndex Int             @default(0)
  round            Int             @default(1)
  name             String?
  startedAt        DateTime?
  endedAt          DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  channel      Channel                 @relation(fields: [channelId], references: [id], onDelete: Cascade)
  campaign     Campaign?               @relation("CampaignEncounters", fields: [campaignId], references: [id], onDelete: SetNull)
  creator      User                    @relation("EncounterCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  participants InitiativeParticipant[]

  @@index([channelId, status])
}

model InitiativeParticipant {
  id           String   @id
  encounterId  String
  name         String
  initiative   Int      @default(0)
  hp           Int      @default(0)
  maxHp        Int      @default(0)
  conditions   Json     @default("[]")
  isPc         Boolean  @default(false)
  characterRef String?
  position     Int      @default(0)
  hidden       Boolean  @default(false)
  createdAt    DateTime @default(now())

  encounter InitiativeEncounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([encounterId, position])
}

// ============================================================================
// Wave 2 — Chat UX, moderation, TTRPG, security, integrations.
// ============================================================================

enum ChannelPostingScope {
  open
  mods_only
  admin_only
}

enum CharacterSystem {
  dnd5e
  pbta
  generic
}

enum IcalTokenKind {
  all
  campaign
}

// ---------- W2 #4 — Link previews (OG/oEmbed unfurl) ------------------------

model LinkPreview {
  id          String   @id
  messageId   String
  url         String
  title       String?
  description String?
  imageUrl    String?
  siteName    String?
  fetchedAt   DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@unique([messageId, url])
}

// ---------- W2 #10 — Append-only edit history -------------------------------

model MessageEdit {
  id        String   @id
  messageId String
  content   String
  editedBy  String
  editedAt  DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  editor  User    @relation("MessageEditor", fields: [editedBy], references: [id], onDelete: Cascade)

  @@index([messageId, editedAt])
}

// ---------- W2 #11 — Character sheets ---------------------------------------

model Character {
  id                  String          @id
  campaignId          String
  ownerUserId         String
  name                String
  conceptOneLiner     String?
  system              CharacterSystem @default(dnd5e)
  /// System-specific shape validated by Zod per `system`. Keep arbitrary
  /// schemas server-agnostic so we can add systems without migrations.
  sheetJson           Json            @default("{}")
  portraitAttachmentId String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  campaign Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  owner    User             @relation("CharacterOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  macros   CharacterMacro[]

  @@index([campaignId])
  @@index([ownerUserId])
}

// ---------- W2 #12 — Macros / quick-roll bar --------------------------------

model CharacterMacro {
  id          String  @id
  characterId String
  label       String
  /// Dice notation interpreted by the existing dice parser.
  notation    String
  /// Optional structured modifier data (advantage flags, damage type, etc).
  modifierJson Json   @default("{}")
  position    Int     @default(0)
  color       String?

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, position])
}

// ---------- W2 #13 — Soundboard ---------------------------------------------

model SoundboardClip {
  id           String   @id
  serverId     String
  name         String
  /// References Attachment.id (audio kind). String FK keeps Attachment
  /// simple; cascade is application-managed if the attachment is removed.
  attachmentId String
  color        String?
  position     Int      @default(0)
  /// Wave 3 #19 — when true, the play button on the soundboard panel cues
  /// the clip with `loop: true` and shows a stop affordance, so this is
  /// the ambient-music pad rather than a one-shot SFX.
  isAmbient    Boolean  @default(false)
  addedBy      String
  createdAt    DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  adder  User   @relation("SoundboardClipAdder", fields: [addedBy], references: [id], onDelete: Cascade)

  @@index([serverId, position])
}

// ---------- W2 #14 — Random tables / loot generators ------------------------

model RandomTable {
  id            String   @id
  serverId      String
  /// Campaign scope is optional — server-wide tables exist (shared loot).
  campaignId    String?
  name          String
  /// Dice notation rolled when the table is invoked (defaults to `1d100`).
  diceNotation  String   @default("1d100")
  ownerId       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  server   Server      @relation(fields: [serverId], references: [id], onDelete: Cascade)
  campaign Campaign?   @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  owner    User        @relation("RandomTableOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  rows     RandomTableRow[]

  @@index([serverId])
  @@index([campaignId])
  @@unique([serverId, name])
}

model RandomTableRow {
  id         String  @id
  tableId    String
  rangeMin   Int
  rangeMax   Int
  label      String
  weight     Int     @default(1)
  resultText String

  table RandomTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@index([tableId, rangeMin])
}

// ---------- W2 #15 — NPC roster ---------------------------------------------

model Npc {
  id                   String   @id
  campaignId           String
  name                 String
  descriptionMd        String?
  portraitAttachmentId String?
  factionTag           String?
  locationTag          String?
  /// Optional stat block — system-agnostic JSON like Character.sheetJson.
  statBlockJson        Json     @default("{}")
  isAlive              Boolean  @default(true)
  createdBy            String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creator  User     @relation("NpcCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

// ---------- W2 #19 — API tokens & incoming webhooks -------------------------

model ApiToken {
  id          String   @id
  userId      String
  label       String
  /// SHA-256 of the token plaintext. Token itself is only shown once at mint.
  tokenHash   String   @unique
  /// Reserved for scoped tokens (e.g. "messages:write"). Empty = full user scope.
  scopes      Json     @default("[]")
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?

  user User @relation("ApiTokenOwner", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model Webhook {
  id              String   @id
  channelId       String
  name            String
  /// Used for URL-bearer and HMAC validation of inbound webhook posts.
  secret          String
  createdBy       String
  createdAt       DateTime @default(now())
  lastDeliveryAt  DateTime?
  revokedAt       DateTime?

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  creator User    @relation("WebhookCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([channelId])
}

// ---------- W2 #20 — iCal subscription tokens -------------------------------

model IcalToken {
  id          String        @id
  userId      String
  kind        IcalTokenKind @default(all)
  /// Set when kind = campaign. Null for the user's all-campaigns feed.
  campaignId  String?
  /// Opaque secret embedded in the feed URL. 32+ bytes random.
  secretToken String        @unique
  createdAt   DateTime      @default(now())
  revokedAt   DateTime?

  user User @relation("IcalTokenOwner", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([secretToken])
}

// ============================================================================
// Wave 3 — chat polish, TTRPG depth, moderation, voice, mobile/ops.
// ============================================================================

enum AutomodAction {
  log_only
  delete
  hold
  warn
  timeout
}

enum WarningTier {
  notice
  warn
  mute
  kick
  ban
}

enum StagePosition {
  audience
  speaker
}

// ---------- W3 #3 — Server stickers -----------------------------------------

model Sticker {
  id           String   @id
  serverId     String
  name         String
  attachmentId String
  uploadedBy   String
  position     Int      @default(0)
  createdAt    DateTime @default(now())

  server     Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  uploader   User   @relation("StickerUploader", fields: [uploadedBy], references: [id], onDelete: Cascade)

  @@unique([serverId, name])
  @@index([serverId, position])
}

// ---------- W3 #7 — Battle map / token grid ---------------------------------

model BattleMap {
  id          String   @id
  campaignId  String
  name        String
  width       Int      @default(20)
  height      Int      @default(20)
  /// Background attachment (image) used as the map backdrop.
  backgroundAttachmentId String?
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  scenes   BattleScene[]

  @@index([campaignId])
}

model BattleScene {
  id        String   @id
  mapId     String
  name      String
  /// Fog-of-war mask: RLE-encoded boolean grid the size of the map.
  fogJson   Json     @default("[]")
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  map    BattleMap     @relation(fields: [mapId], references: [id], onDelete: Cascade)
  tokens BattleToken[]

  @@index([mapId])
}

model BattleToken {
  id           String   @id
  sceneId      String
  /// Optional link to a Character or InitiativeParticipant — the client uses
  /// this to sync HP / status. Free-form so NPCs without a model still work.
  characterRef String?
  label        String
  /// Hex color for non-PC tokens.
  color        String?
  /// Grid coordinates (cells, not pixels).
  x            Int      @default(0)
  y            Int      @default(0)
  /// Width / height in grid cells.
  w            Int      @default(1)
  h            Int      @default(1)
  hp           Int?
  maxHp        Int?
  isPc         Boolean  @default(false)
  hidden       Boolean  @default(false)
  createdAt    DateTime @default(now())

  scene BattleScene @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@index([sceneId])
}

// ---------- W3 #9 — In-world calendar / timeline ----------------------------

model InWorldCalendar {
  id          String   @id
  campaignId  String   @unique
  /// Calendar system: 'gregorian' | 'forgotten_realms' | 'custom' (JSON).
  system      String   @default("gregorian")
  /// For custom systems, a free-form month/day definition.
  systemJson  Json     @default("{}")
  /// Current in-world date, as an ISO-ish string ('1492-DR-3' or 'YYYY-MM-DD').
  currentDate String   @default("0001-01-01")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  entries  TimelineEntry[]
}

model TimelineEntry {
  id          String   @id
  calendarId  String
  /// Date the event happened in-world.
  inWorldDate String
  title       String
  body        String?
  /// Optional link to a CampaignSession when the entry was logged in-session.
  sessionId   String?
  createdBy   String
  createdAt   DateTime @default(now())

  calendar InWorldCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  @@index([calendarId, inWorldDate])
}

// ---------- W3 #13 — Encounter templates ------------------------------------

model EncounterTemplate {
  id        String   @id
  serverId  String
  ownerId   String
  name      String
  /// Array of { name, initiative, hp, maxHp, isPc, conditions, characterRef } —
  /// same shape as InitiativeParticipant inputs.
  participantsJson Json @default("[]")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  owner  User   @relation("EncounterTemplateOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([serverId])
}

// ---------- W3 #15 — Auto-moderation rules ---------------------------------

model AutomodRule {
  id        String        @id
  serverId  String
  name      String
  /// Rule kind decides how `pattern` is interpreted: 'regex', 'wordlist',
  /// 'link_rate', 'message_rate'.
  kind      String
  pattern   String
  action    AutomodAction @default(log_only)
  enabled   Boolean       @default(true)
  position  Int           @default(0)
  /// Optional reason posted to the audit log when triggered.
  reason    String?
  createdBy String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, position])
}

// ---------- W3 #16 — Warnings / strike escalation ---------------------------

model Warning {
  id          String      @id
  serverId    String
  userId      String
  moderatorId String
  tier        WarningTier @default(warn)
  reason      String?
  createdAt   DateTime    @default(now())

  server    Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user      User   @relation("WarningTarget", fields: [userId], references: [id], onDelete: Cascade)
  moderator User   @relation("WarningModerator", fields: [moderatorId], references: [id], onDelete: Cascade)

  @@index([serverId, userId])
  @@index([userId, createdAt])
}

// ---------- W3 #17 — Verification gating ------------------------------------

model JoinGate {
  serverId        String   @id
  rulesMd         String   @default("")
  /// Array of { id, label, required } — answers stored on JoinGateAnswer.
  questionsJson   Json     @default("[]")
  enabled         Boolean  @default(false)
  updatedAt       DateTime @updatedAt

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
}

model JoinGateAnswer {
  serverId   String
  userId     String
  /// { questionId: "free-form answer" } shaped JSON.
  answersJson Json    @default("{}")
  submittedAt DateTime @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?
  approved    Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([serverId, userId])
  @@index([serverId, reviewedAt])
}

// ---------- W3 #19 — Server templates ---------------------------------------

model ServerTemplate {
  id         String   @id
  authorId   String
  name       String
  description String?
  /// Full snapshot — categories, channels, roles, permission overwrites,
  /// safety policy. Versioned via a schema marker inside the JSON.
  payloadJson Json
  /// Optional canonical icon. If absent the SPA falls back to a placeholder.
  iconAttachmentId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  author User @relation("ServerTemplateAuthor", fields: [authorId], references: [id], onDelete: Cascade)
}

// ---------- W3 #20 — Server backups -----------------------------------------

model ServerBackup {
  id          String   @id
  serverId    String
  createdBy   String
  /// 'pending' | 'running' | 'ready' | 'failed'
  status      String   @default("pending")
  /// Legacy pointer kept for backwards compat — newer code uses storageKey.
  attachmentId String?
  /// Where the archive zip lives in storage when status='ready'.
  storageBucket String?
  storageKey    String?
  sizeBytes     Int?
  failureReason String?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime @default(now())

  server  Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  creator User   @relation("ServerBackupCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([serverId, createdAt])
}

// ---------- W3 #26 — Web Push subscriptions ---------------------------------

model PushSubscription {
  id        String   @id
  userId    String
  endpoint  String   @unique
  /// PEM-encoded p256dh + auth keys.
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  lastUsedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------- W3 #37 — RSS feed input -----------------------------------------

model RssSubscription {
  id            String   @id
  channelId     String
  url           String
  /// Optional display name for the integration messages.
  feedTitle     String?
  /// Latest item GUID we've already posted, used as a high-water-mark.
  lastSeenGuid  String?
  enabled       Boolean  @default(true)
  pollIntervalMinutes Int @default(15)
  lastPolledAt  DateTime?
  createdBy     String
  createdAt     DateTime @default(now())

  @@index([channelId])
  @@index([enabled, lastPolledAt])
  @@unique([channelId, url])
}
