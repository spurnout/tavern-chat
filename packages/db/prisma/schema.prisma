// Tavern — Prisma schema
//
// IDs: ULID strings (26 chars, Crockford base32) generated in app code.
// Permissions: stored as Decimal(20,0) so a 64-bit BigInt fits without overflow.
//             We serialize them as strings on the wire. Decimal(20,0) is enough
//             for an unsigned 64-bit value.
// JSON fields use Postgres `jsonb`.
//
// Phases marked in section comments — every model is part of the initial
// migration so we don't churn migrations as features land.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
  // `native` covers the host the dev runs on; `linux-musl-openssl-3.0.x` is
  // for the node:22-alpine container images (Alpine 3.20 ships OpenSSL 3).
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AUTH / USERS  (Phase 0)
// ============================================================================

/// User presence — exposed in the member sidebar and used to gate
/// notification sounds. `offline` is derived (no live gateway socket),
/// `idle` is derived (no client heartbeat for the idle window), `active`
/// is derived (live socket + recent activity). `dnd` is user-set via
/// `User.manualDnd`; while set, the presence is pinned to `dnd` whenever
/// the user is online.
enum Presence {
  active
  idle
  dnd
  offline
}

model User {
  id                  String    @id
  username            String    @unique
  usernameLower       String    @unique
  displayName         String
  email               String    @unique
  emailLower          String    @unique
  passwordHash        String
  avatarAttachmentId  String?
  bio                 String?
  isInstanceAdmin     Boolean   @default(false)
  // Wave 2 #19: bot accounts authenticate via API tokens only.
  isBot               Boolean   @default(false)
  postingLockedUntil  DateTime?
  uploadsLockedUntil  DateTime?
  // Wave 2 #16: TOTP 2FA.
  totpSecret          String?
  totpEnabled         Boolean   @default(false)
  totpBackupCodes     Json      @default("[]")
  // Wave 3 #36: SSO / OIDC. When the user logged in via an external IdP,
  // (oidcIssuer, oidcSubject) is the global identity. The pair is unique
  // (see @@unique below) so a re-login matches the same Tavern account.
  oidcIssuer          String?
  oidcSubject         String?
  // Wave 2 #18: account deletion grace period.
  scheduledDeleteAt   DateTime?
  // Wave 3 #30/#33: appearance preferences (theme, font, motion).
  themePreference     String?   @db.VarChar(40)
  fontPreference      String?   @db.VarChar(40)
  reduceMotion        Boolean   @default(false)
  // Wave 3 #34: UI locale (BCP-47). Null falls back to browser default.
  localePreference    String?   @db.VarChar(20)
  // Failed-login lockout — incremented on each invalid login, reset on
  // success. When the threshold is reached, loginLockedUntil is set; further
  // attempts inside the window are rejected before the password is even
  // checked. Defends against slow-and-low credential stuffing without
  // requiring Redis.
  failedLoginAttempts Int       @default(0)
  loginLockedUntil    DateTime?
  // Presence: current state is in `presence`; `manualDnd` is sticky so
  // DND survives reconnects. The application sets `presenceUpdatedAt`
  // explicitly when transitioning state (it is NOT @updatedAt to avoid
  // touching it on unrelated profile edits).
  presence            Presence  @default(offline)
  presenceUpdatedAt   DateTime  @default(now())
  manualDnd           Boolean   @default(false)
  // Rich-profile fields surfaced by the member profile card. socialLinks is
  // jsonb (array of { label, url }); validated by zod on write.
  pronouns               String?   @db.VarChar(32)
  accentColor            String?   @db.VarChar(7)
  timezone               String?   @db.VarChar(64)
  customStatus           String?   @db.VarChar(128)
  customStatusExpiresAt  DateTime? @db.Timestamptz(3)
  socialLinks            Json      @default("[]")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  sessions             Session[]
  passwordResets       PasswordReset[]       @relation("PasswordResetUser")
  webAuthnCredentials  WebAuthnCredential[]  @relation("WebAuthnCredentialOwner")
  dataExports          UserDataExport[]      @relation("UserDataExportOwner")
  messageDrafts        MessageDraft[]        @relation("MessageDraftOwner")
  safetyEntries        CampaignSafetyEntry[] @relation("SafetyEntryAuthor")
  ownedServers         Server[]              @relation("ServerOwner")
  memberships          ServerMember[]
  roleAssignments      ServerMemberRole[]
  authoredMessages     Message[]             @relation("MessageAuthor")
  uploadedAttachments  Attachment[]          @relation("AttachmentUploader")
  reactions            MessageReaction[]
  diceRolls            DiceRoll[]
  campaignMemberships  CampaignMember[]
  campaignsAsGm        Campaign[]            @relation("CampaignGm")
  authoredHandouts     Handout[]             @relation("HandoutAuthor")
  authoredNotes        CampaignNote[]        @relation("NoteAuthor")
  rsvps                CampaignSessionRsvp[]
  gameNightRsvps       GameNightRsvp[]
  proposedGames        GameNightCandidate[]
  votes                GameNightVote[]
  reports              Report[]              @relation("Reporter")
  moderationActions    ModerationAction[]    @relation("Moderator")
  auditLogActor        AuditLogEntry[]       @relation("AuditActor")
  voiceStates          VoiceState[]
  invitesCreated       Invite[]              @relation("InviteCreator")
  customEmojisCreated  CustomEmoji[]         @relation("EmojiCreator")
  ownedBoardGames      BoardGame[]           @relation("BoardGameOwner")
  createdGameNights    GameNight[]           @relation("GameNightCreator")
  handoutAccess        HandoutVisibleUser[]
  bans                 ServerBan[]           @relation("BannedUser")
  bansIssued           ServerBan[]           @relation("BannedByUser")
  notificationPreference        UserNotificationPreference?
  serverNotificationPreferences ServerMemberNotificationPreference[]
  dmChannelsCreated     DmChannel[]       @relation("DmChannelCreator")
  dmChannelMemberships  DmChannelMember[]
  // Phase 1.3 — activity inbox / unread state
  channelReadStates     UserChannelReadState[]
  mentionsReceived      UserMention[]              @relation("MentionUser")
  // Phase 2.1 / 2.2 — pinned and saved messages
  pinnedMessagesAuthored PinnedMessage[]           @relation("PinnedBy")
  savedMessages         SavedMessage[]             @relation("SavedByUser")
  // Phase 3.1 / 3.2 / 3.3 — threads, polls, scheduled dispatch
  threadsCreated        Thread[]                   @relation("ThreadCreator")
  pollsCreated          Poll[]                     @relation("PollCreator")
  pollVotes             PollVote[]                 @relation("PollVoter")
  scheduledDispatches   ScheduledDispatch[]        @relation("DispatchOwner")
  // Phase 4 — initiative tracker
  encountersCreated     InitiativeEncounter[]      @relation("EncounterCreator")
  // Wave 2 — characters / NPCs / tables / soundboard / webhooks / tokens / etc.
  characters            Character[]                @relation("CharacterOwner")
  npcsCreated           Npc[]                      @relation("NpcCreator")
  randomTablesOwned     RandomTable[]              @relation("RandomTableOwner")
  soundboardClipsAdded  SoundboardClip[]           @relation("SoundboardClipAdder")
  webhooksCreated       Webhook[]                  @relation("WebhookCreator")
  apiTokens             ApiToken[]                 @relation("ApiTokenOwner")
  icalTokens            IcalToken[]                @relation("IcalTokenOwner")
  messageEdits          MessageEdit[]              @relation("MessageEditor")
  // Wave 3 back-relations.
  pushSubscriptions     PushSubscription[]
  stickersUploaded      Sticker[]                  @relation("StickerUploader")
  warningsReceived      Warning[]                  @relation("WarningTarget")
  warningsIssued        Warning[]                  @relation("WarningModerator")
  encounterTemplates    EncounterTemplate[]        @relation("EncounterTemplateOwner")
  serverTemplates       ServerTemplate[]           @relation("ServerTemplateAuthor")
  joinGateAnswers       JoinGateAnswer[]
  serverBackupsCreated  ServerBackup[]             @relation("ServerBackupCreator")
  cardDecksCreated      CardDeck[]                 @relation("CardDeckCreator")
  watchPartiesHosted    WatchParty[]               @relation("WatchPartyHost")
  recapsGenerated       SessionRecap[]             @relation("RecapAuthor")
  breakoutsCreated      BreakoutGroup[]            @relation("BreakoutCreator")
  breakoutMemberships   BreakoutMember[]           @relation("BreakoutMembership")
  recordingsCaptured    SessionRecording[]         @relation("Recorder")
  whiteboardsUpdated    Whiteboard[]               @relation("WhiteboardUpdater")

  @@unique([oidcIssuer, oidcSubject], map: "User_oidc_idx")
  @@index([customStatusExpiresAt], map: "User_customStatusExpiresAt_idx")
}

model Session {
  id                String   @id
  userId            String
  refreshTokenHash  String   @unique
  deviceName        String?
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime @default(now())
  expiresAt         DateTime
  revokedAt         DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ============================================================================
// PASSWORD RESET  (Wave 3)
// ============================================================================
//
// One row per outstanding reset request. `tokenHash` is SHA-256 of the opaque
// token mailed to the user; the plaintext token is never persisted. Rows are
// single-use (`usedAt`) and time-limited (`expiresAt`); a periodic sweep can
// purge expired rows but is not required for correctness — the service path
// rejects them on read.

model PasswordReset {
  id         String    @id
  userId     String
  tokenHash  String    @unique
  ipAddress  String?
  userAgent  String?
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  user User @relation("PasswordResetUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ============================================================================
// WEBAUTHN PASSKEYS  (Wave 3)
// ============================================================================
//
// One row per enrolled authenticator (hardware key, platform passkey, etc.).
// `credentialId` is the raw bytes the authenticator returns and is what we
// look up on assertion; `publicKey` is the COSE-encoded public key used to
// verify signatures. `counter` is the authenticator's signature counter — we
// store it monotonically so a cloned credential whose counter rolls back can
// be detected. Ephemeral registration/authentication challenges are NOT
// persisted; they live in an in-process Map keyed by user/IP for ~5 minutes.

model WebAuthnCredential {
  id            String    @id
  userId        String
  credentialId  Bytes     @unique
  publicKey     Bytes
  counter       BigInt    @default(0)
  transports    String[]
  deviceName    String?
  createdAt     DateTime  @default(now())
  lastUsedAt    DateTime?

  user User @relation("WebAuthnCredentialOwner", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================================================
// USER DATA EXPORTS  (Wave 3)
// ============================================================================
//
// One row per requested per-user data export. Replaces the prior abuse of
// `ScheduledDispatch` rows (which was always a placeholder). Status moves
// pending → running → ready | failed; on success, `storageKey` points to a
// zip in the main storage bucket and `expiresAt` is when the row + zip get
// reaped by a maintenance sweep so we don't accumulate gigabytes per user.

model UserDataExport {
  id            String    @id
  userId        String
  status        String
  storageBucket String?
  storageKey    String?
  sizeBytes     Int?
  failureReason String?
  requestedAt   DateTime  @default(now())
  startedAt     DateTime?
  finishedAt    DateTime?
  expiresAt     DateTime

  user User @relation("UserDataExportOwner", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([status])
}

// ============================================================================
// MESSAGE DRAFTS  (Wave 3 — #5 cross-device draft sync)
// ============================================================================
//
// One row per (user, channel). The client debounces writes and clears the
// row on send/cancel. Drafts are cheap (text only, no attachments) and bound
// in size by MAX_MESSAGE_LENGTH; we don't expire them — the user's own
// signal ("I sent the message" or "I cleared the composer") is the truth.

model MessageDraft {
  userId    String
  channelId String
  content   String
  updatedAt DateTime @updatedAt

  user    User    @relation("MessageDraftOwner", fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([userId, channelId])
  @@index([userId, updatedAt])
}

// ============================================================================
// INVITES  (Phase 0/2)
// ============================================================================

enum InviteScope {
  instance
  server
}

model Invite {
  id            String      @id
  code          String      @unique
  scope         InviteScope
  serverId      String?
  channelId     String?
  createdById   String?
  maxUses       Int?
  uses          Int         @default(0)
  expiresAt     DateTime?
  revokedAt     DateTime?
  createdAt     DateTime    @default(now())

  server     Server?  @relation(fields: [serverId], references: [id], onDelete: Cascade)
  channel    Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  createdBy  User?    @relation("InviteCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([serverId])
  @@index([code])
}

// ============================================================================
// SERVERS / MEMBERS / ROLES  (Phase 1/2)
// ============================================================================

model Server {
  id                  String   @id
  ownerUserId         String
  name                String
  description         String?
  iconAttachmentId    String?
  defaultRoleId       String?  @unique
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  owner          User                @relation("ServerOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  defaultRole    Role?               @relation("ServerEveryoneRole", fields: [defaultRoleId], references: [id], onDelete: SetNull)
  members        ServerMember[]
  roles          Role[]              @relation("ServerRoles")
  channels       Channel[]
  invites        Invite[]
  campaigns      Campaign[]
  boardGames     BoardGame[]
  gameNights     GameNight[]
  customEmojis   CustomEmoji[]
  reports        Report[]
  auditEntries   AuditLogEntry[]
  // Wave 3 #18 — mod log channel mirror. When set, moderation actions
  // publish a formatted message into this channel.
  modLogChannelId String?
  safetyPolicy   SafetyPolicy?
  bans           ServerBan[]
  memberNotificationPreferences ServerMemberNotificationPreference[]
  // Wave 2 — soundboard and instance-level random tables.
  soundboardClips SoundboardClip[]
  randomTables    RandomTable[]
  // Wave 3 — server-scoped new content.
  stickers        Sticker[]
  automodRules    AutomodRule[]
  warnings        Warning[]
  joinGate        JoinGate?
  encounterTemplates EncounterTemplate[]
  serverBackups   ServerBackup[]
  cardDecks       CardDeck[]

  @@index([ownerUserId])
}

model ServerMember {
  serverId      String
  userId        String
  nickname      String?
  joinedAt      DateTime  @default(now())
  timeoutUntil  DateTime?
  /// Wave 3 #40 — per-server custom status override. Null falls back to
  /// the global `User.customStatus`. Lets a GM be "in session" in one
  /// tavern without leaking that into every other community.
  customStatus  String?   @db.VarChar(128)
  /// Wave 3 #17 — true once the member has passed the server's join gate
  /// (rules acceptance + free-text answers). Pending members can't post.
  gatePassedAt  DateTime?
  /// Wave 3 #16 — accumulated strike tier (0 = clean, escalates with each
  /// warning). Drives automatic punishment escalation.
  strikeTier    Int       @default(0)

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  roles  ServerMemberRole[]

  @@id([serverId, userId])
  @@index([userId])
}

/// PERM-002: BAN_MEMBERS enforcement table.
///
/// A row here means the user is banned from the server. The gateway IDENTIFY
/// handler and invite-consume path both consult this table; an active row
/// blocks both new connections and rejoin attempts. `expiresAt` supports
/// temporary bans (e.g. 30-day timeouts); a NULL value is a permanent ban.
model ServerBan {
  serverId       String
  userId         String
  bannedByUserId String?
  reason         String?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())

  server   Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user     User   @relation("BannedUser", fields: [userId], references: [id], onDelete: Cascade)
  bannedBy User?  @relation("BannedByUser", fields: [bannedByUserId], references: [id], onDelete: SetNull)

  @@id([serverId, userId])
  @@index([userId])
  @@index([expiresAt])
}

model Role {
  id            String  @id
  serverId      String
  name          String
  color         Int     @default(0)
  position      Int     @default(0)
  permissions   Decimal @default(0) @db.Decimal(20, 0)
  mentionable   Boolean @default(false)
  hoist         Boolean @default(false)
  isEveryone    Boolean @default(false)
  createdAt     DateTime @default(now())

  server                  Server                @relation("ServerRoles", fields: [serverId], references: [id], onDelete: Cascade)
  serverAsDefault         Server?               @relation("ServerEveryoneRole")
  memberAssignments       ServerMemberRole[]
  channelOverwrites       PermissionOverwrite[]

  @@unique([serverId, name])
  @@index([serverId])
}

model ServerMemberRole {
  serverId String
  userId   String
  roleId   String
  assignedAt DateTime @default(now())

  member ServerMember @relation(fields: [serverId, userId], references: [serverId, userId], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([serverId, userId, roleId])
  @@index([roleId])
}

// ============================================================================
// CHANNELS / OVERWRITES  (Phase 1/2)
// ============================================================================

enum ChannelType {
  category
  text
  voice
  campaign
  session
  board_game
  /// Wave 3 #24 — stage / broadcast voice channel. Members default to muted
  /// listeners; hosts approve raise-hand requests to grant speaker.
  stage
  /// Wave 3 #8 — forum-style channel. Each message posted at root becomes
  /// the seed of a thread; the channel itself shows a list of threads
  /// rather than a flat timeline. Replies happen inside the thread.
  forum
}

model Channel {
  id            String       @id
  serverId      String
  parentId      String?
  campaignId    String?
  gameNightId   String?
  type          ChannelType
  name          String
  topic         String?
  position      Int          @default(0)
  nsfw          Boolean      @default(false)
  videoEnabled  Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  server      Server                @relation(fields: [serverId], references: [id], onDelete: Cascade)
  parent      Channel?              @relation("ChannelParent", fields: [parentId], references: [id], onDelete: SetNull)
  children    Channel[]             @relation("ChannelParent")
  campaign    Campaign?             @relation("CampaignChannels", fields: [campaignId], references: [id], onDelete: SetNull)
  gameNight   GameNight?            @relation("GameNightChannels", fields: [gameNightId], references: [id], onDelete: SetNull)
  messages    Message[]
  overwrites  PermissionOverwrite[]
  invites     Invite[]
  voiceStates VoiceState[]
  diceRolls   DiceRoll[]
  campaignTextSessions    CampaignSession[] @relation("SessionTextChannel")
  campaignVoiceSessions   CampaignSession[] @relation("SessionVoiceChannel")
  gameNightTextSessions   GameNight[]       @relation("GameNightTextChannel")
  gameNightVoiceSessions  GameNight[]       @relation("GameNightVoiceChannel")
  campaignDefaultLink     Campaign?         @relation("CampaignDefaultChannel")
  // Phase 1.3 / 2.1 / 3.1 / 4 — new per-channel surfaces
  readStates              UserChannelReadState[]
  mentions                UserMention[]
  pinnedMessages          PinnedMessage[]
  threads                 Thread[]
  encounters              InitiativeEncounter[]
  messageDrafts           MessageDraft[]
  watchParty              WatchParty?
  /// Wave 3 #29 — breakout groups parented to this channel.
  breakoutGroups          BreakoutGroup[]
  /// Wave 3 #32 — session recordings captured in this channel.
  sessionRecordings       SessionRecording[]
  /// Wave 3 #34 — shared canvas state (one per channel).
  whiteboard              Whiteboard?
  // Wave 2 #8 — per-channel slow mode (seconds between sends per member).
  slowmodeSeconds         Int                   @default(0)
  // Wave 2 #9 — posting scope. `open` = anyone with SEND_MESSAGES; `mods_only`
  // requires MANAGE_MESSAGES; `admin_only` requires ADMINISTRATOR.
  postingScope            ChannelPostingScope   @default(open)
  // Wave 2 #19 — incoming webhooks bound to this channel.
  webhooks                Webhook[]

  @@index([serverId, position])
  @@index([parentId])
}

enum OverwriteTargetType {
  role
  user
}

model PermissionOverwrite {
  id          String              @id
  channelId   String
  targetType  OverwriteTargetType
  targetId    String
  allow       Decimal             @default(0) @db.Decimal(20, 0)
  deny        Decimal             @default(0) @db.Decimal(20, 0)
  createdAt   DateTime            @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  role    Role?   @relation(fields: [targetId], references: [id], onDelete: Cascade, map: "PermissionOverwrite_role_fkey")

  @@unique([channelId, targetType, targetId])
  @@index([channelId])
}

// ============================================================================
// MESSAGES / ATTACHMENTS / REACTIONS  (Phase 1/2/3)
// ============================================================================

enum MessageType {
  default
  system
  voice
  dice_roll
  session_event
}

enum SafetyState {
  allowed
  labeled
  warning
  blurred
  held
  quarantined
  blocked
}

model Message {
  id                 String      @id
  // serverId / channelId are non-null for server messages, null for DM
  // messages; dmChannelId is the inverse. The application enforces the
  // invariant "exactly one of channelId / dmChannelId is set" — Prisma
  // doesn't model CHECK constraints, so server-side validation in the
  // route handlers is the gate.
  serverId           String?
  channelId          String?
  dmChannelId        String?
  authorId           String
  type               MessageType @default(default)
  content            String      @default("")
  replyToMessageId   String?
  editedAt           DateTime?
  deletedAt          DateTime?
  safetyState        SafetyState @default(allowed)
  diceRollId         String?     @unique
  nonce              String?
  /// Phase 3.1: when non-null, this message is inside a Thread.
  threadId           String?
  /// Phase 3.1: true when the message is itself the root of a Thread
  /// branch. Set by the threads route after creating the Thread row.
  isThreadRoot       Boolean     @default(false)
  createdAt          DateTime    @default(now())

  channel       Channel?          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  dmChannel     DmChannel?        @relation("DmChannelMessages", fields: [dmChannelId], references: [id], onDelete: Cascade)
  author        User              @relation("MessageAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  replyTo       Message?          @relation("MessageReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies       Message[]         @relation("MessageReplies")
  attachments   Attachment[]
  reactions     MessageReaction[]
  diceRoll      DiceRoll?         @relation("DiceRollMessage", fields: [diceRollId], references: [id])
  // Phase 1.3 / 2.1 / 2.2 / 3.1 / 3.2 — new per-message surfaces
  mentions      UserMention[]
  pinnedAs      PinnedMessage?
  savedAs       SavedMessage[]
  thread        Thread?           @relation("ThreadMessages", fields: [threadId], references: [id], onDelete: SetNull)
  threadRoot    Thread?           @relation("ThreadRoot")
  poll          Poll?
  // Wave 2 #5 — forward provenance. Both fields set together when this
  // message is a forward; null otherwise. Source FK uses SetNull so
  // deletion of the original doesn't cascade-destroy forwards.
  forwardedFromMessageId String?
  forwardedFromChannelId String?
  forwardedFrom Message? @relation("MessageForward", fields: [forwardedFromMessageId], references: [id], onDelete: SetNull)
  forwardedAs   Message[] @relation("MessageForward")
  // Wave 2 #10 — append-only edit history.
  edits         MessageEdit[]
  // Wave 2 #4 — OG-unfurled link previews (populated async by the worker).
  linkPreviews  LinkPreview[]

  @@index([channelId, createdAt])
  @@index([channelId, id])
  @@index([dmChannelId, createdAt])
  @@index([authorId])
  @@index([threadId])
  @@index([forwardedFromMessageId])
  @@unique([channelId, nonce])
  @@unique([dmChannelId, nonce])
}

enum AttachmentKind {
  image
  gif
  video
  audio
  voice_message
  map
  handout
  character_asset
  file
}

enum AttachmentStatus {
  pending
  uploaded
  processing
  ready
  failed
  blocked
  quarantined
}

model Attachment {
  id                  String           @id
  uploaderId          String
  serverId            String?
  channelId           String?
  messageId           String?
  kind                AttachmentKind
  filename            String
  mimeType            String
  sizeBytes           BigInt
  width               Int?
  height              Int?
  durationMs          Int?
  waveform            Int[]            @default([])
  storageBucket       String
  storageKey          String
  thumbnailKey        String?
  status              AttachmentStatus @default(pending)
  rejectionReason     String?
  scanResult          Json?
  scannedAt           DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  uploader User     @relation("AttachmentUploader", fields: [uploaderId], references: [id], onDelete: Cascade)
  message  Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  /// Wave 3 #32 — when this attachment is a session recording, the back-ref.
  sessionRecording SessionRecording? @relation("SessionRecordingAttachment")

  @@index([uploaderId])
  @@index([status])
  @@index([messageId])
}

model MessageReaction {
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([messageId, userId, emoji])
  @@index([messageId, emoji])
}

model CustomEmoji {
  id              String   @id
  serverId        String
  name            String
  attachmentId    String   @unique
  createdById     String?
  createdAt       DateTime @default(now())

  server     Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  createdBy  User?  @relation("EmojiCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([serverId, name])
  @@index([serverId])
}

// ============================================================================
// VOICE STATE  (Phase 3)
// ============================================================================

model VoiceState {
  serverId       String
  userId         String
  channelId      String?
  selfMute       Boolean   @default(false)
  selfDeaf       Boolean   @default(false)
  serverMute     Boolean   @default(false)
  serverDeaf     Boolean   @default(false)
  cameraOn       Boolean   @default(false)
  screenSharing  Boolean   @default(false)
  /// Wave 3 #25 — only meaningful when the joined channel is `type='stage'`.
  /// Default behaviour: everyone joins as `audience`; hosts (MANAGE_CHANNELS)
  /// can promote to `speaker` so they're granted publish-audio on next token
  /// issue. `handRaisedAt` flags an audience member asking to be promoted.
  stagePosition  StagePosition?
  handRaisedAt   DateTime?
  joinedAt       DateTime?
  updatedAt      DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  @@id([serverId, userId])
  @@index([channelId])
}

// ============================================================================
// CAMPAIGNS  (Phase 4)
// ============================================================================

enum CampaignStatus {
  planning
  active
  paused
  completed
  archived
}

model Campaign {
  id                   String         @id
  serverId             String
  name                 String
  description          String?
  gameSystem           String?
  status               CampaignStatus @default(planning)
  gmUserId             String
  defaultChannelId     String?        @unique
  rulesJson            Json?
  safetyBoundariesJson Json?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  server          Server            @relation(fields: [serverId], references: [id], onDelete: Cascade)
  gm              User              @relation("CampaignGm", fields: [gmUserId], references: [id], onDelete: Restrict)
  defaultChannel  Channel?          @relation("CampaignDefaultChannel", fields: [defaultChannelId], references: [id], onDelete: SetNull)
  channels        Channel[]         @relation("CampaignChannels")
  members         CampaignMember[]
  sessions        CampaignSession[]
  notes           CampaignNote[]
  handouts        Handout[]
  // Phase 4 — initiative encounters belonging to this campaign
  encounters      InitiativeEncounter[] @relation("CampaignEncounters")
  // Wave 2 — characters, NPCs, and per-campaign random tables.
  characters      Character[]
  npcs            Npc[]
  randomTables    RandomTable[]
  // Wave 3 — battle maps + in-world calendar.
  battleMaps      BattleMap[]
  calendar        InWorldCalendar?
  /// Wave 3 #23 — collaborative safety entries (lines, veils, stars, wishes).
  safetyEntries   CampaignSafetyEntry[]
  /// Wave 3 #48 — LLM-generated recaps tied to this campaign / its sessions.
  recaps          SessionRecap[]

  @@index([serverId])
  @@index([gmUserId])
}

// ============================================================================
// CAMPAIGN SAFETY  (Wave 3 — #23 safety tools panel)
// ============================================================================
//
// One row per piece of safety feedback inside a campaign. Lines and veils
// (off-limits content) sit alongside stars (what the table loved) and
// wishes (what the table wants more of) — the four-poled "safety toolkit"
// most modern TTRPG groups recognise. The GM-set high-level boundaries
// already live on `Campaign.safetyBoundariesJson`; this model is for the
// collaborative, mid-campaign feedback loop.

model CampaignSafetyEntry {
  id         String   @id
  campaignId String
  authorId   String
  /// 'line' | 'veil' | 'star' | 'wish' | 'note'
  kind       String
  content    String
  /// When true, only the GM + the author can read it. Defaults to false
  /// — the whole point of stars and wishes is that the whole table sees
  /// them. Lines and veils are usually shared with the GM only; use
  /// isPrivate=true for those.
  isPrivate  Boolean  @default(false)
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  author   User     @relation("SafetyEntryAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([campaignId, createdAt])
  @@index([authorId])
}

// ============================================================================
// CARD DECKS  (Wave 3 — #20)
// ============================================================================
//
// Per-server custom decks (Deck of Many Things, fate decks, character
// motivations, etc.). Cards are stored as a JSON array so adding a new
// `body` or `imageUrl` field later doesn't need a migration. Draws are
// stateless — there's no per-instance "stack with cards removed" yet, just
// a uniform-random pull from the deck.

model CardDeck {
  id          String   @id
  serverId    String
  name        String
  description String?
  /// Array of cards: [{ id, label, body? }, ...]. Application-side schema:
  /// see packages/shared schemas/cards.ts.
  cardsJson   Json
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  server  Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  creator User   @relation("CardDeckCreator", fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([serverId])
}

// ============================================================================
// WATCH PARTIES  (Wave 3 — #26)
// ============================================================================
//
// One active watch party per voice channel. The host controls playback;
// state updates propagate to viewers via gateway events. Late joiners read
// the current row to render the right URL and seek to (currentSec +
// elapsed-since-lastUpdatedAt) on play.
//
// Sources supported initially:
//   - 'mp4'      direct video URL the operator's CDN can serve
//   - 'youtube'  embed via the YouTube iframe API
// Other sources (HLS, Twitch) are documented as follow-ups; the column type
// is a free-form string so adding them is just a UI change.

model WatchParty {
  id             String   @id
  channelId      String   @unique
  hostUserId     String
  videoUrl       String
  source         String
  startedAt      DateTime @default(now())
  currentSec     Float    @default(0)
  isPlaying      Boolean  @default(false)
  lastUpdatedAt  DateTime @updatedAt

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  host    User    @relation("WatchPartyHost", fields: [hostUserId], references: [id], onDelete: Cascade)

  @@index([hostUserId])
}

// ============================================================================
// AI SESSION RECAPS  (Wave 3 — #48)
// ============================================================================
//
// A recap is the LLM-generated summary of a campaign session. The actual
// inference happens off-instance — Tavern POSTs the transcript to an
// operator-configured OpenAI-compatible endpoint (OpenAI, Ollama,
// llama.cpp's server, OpenRouter, etc.) and stores the response. Operators
// who don't configure an LLM endpoint get a clear 503; the rest of Tavern
// keeps working.

model SessionRecap {
  id          String   @id
  campaignId  String
  sessionId   String?
  body        String
  modelUsed   String
  generatedBy String
  createdAt   DateTime @default(now())

  campaign Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  session  CampaignSession? @relation("SessionRecaps", fields: [sessionId], references: [id], onDelete: SetNull)
  author   User             @relation("RecapAuthor", fields: [generatedBy], references: [id], onDelete: Cascade)

  @@index([campaignId, createdAt])
}

// ============================================================================
// BREAKOUT ROOMS  (Wave 3 — #29)
// ============================================================================
//
// Breakouts split a parent voice channel into N sub-rooms backed by distinct
// LiveKit room names. The host POSTs to create groups + assign members;
// each client receives a BREAKOUT_OPEN gateway event and swaps its LiveKit
// connection over to the group's room. `endsAt` is advisory (auto-merge
// timer); the host can also end the breakout early.

model BreakoutGroup {
  id              String   @id
  parentChannelId String
  name            String
  livekitRoom     String   @unique
  endsAt          DateTime?
  createdBy       String
  endedAt         DateTime?
  createdAt       DateTime @default(now())

  parent  Channel          @relation(fields: [parentChannelId], references: [id], onDelete: Cascade)
  creator User             @relation("BreakoutCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  members BreakoutMember[]

  @@index([parentChannelId])
}

model BreakoutMember {
  groupId  String
  userId   String
  joinedAt DateTime?

  group BreakoutGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User          @relation("BreakoutMembership", fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
}

// ============================================================================
// SESSION RECORDINGS  (Wave 3 — #32)
// ============================================================================
//
// One row per saved recording. The actual .webm is an Attachment row;
// SessionRecording links it to the channel + recorder + window. Consent is
// negotiated live via gateway events (RECORDING_CONSENT_*) and isn't
// persisted — it's a per-session in-memory state.

model SessionRecording {
  id           String   @id
  channelId    String
  attachmentId String   @unique
  recordedBy   String
  startedAt    DateTime
  endedAt      DateTime
  createdAt    DateTime @default(now())

  channel    Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  attachment Attachment @relation("SessionRecordingAttachment", fields: [attachmentId], references: [id], onDelete: Cascade)
  recorder   User       @relation("Recorder", fields: [recordedBy], references: [id], onDelete: Cascade)

  @@index([channelId, createdAt])
}

// ============================================================================
// WHITEBOARD  (Wave 3 — #34)
// ============================================================================
//
// One persistent canvas per channel. `strokesJson` is the full snapshot
// (last-write-wins per stroke); live deltas propagate via
// WHITEBOARD_STROKE gateway events. Clearing is its own event for clarity.

model Whiteboard {
  id          String   @id
  channelId   String   @unique
  strokesJson Json
  updatedBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  updater User    @relation("WhiteboardUpdater", fields: [updatedBy], references: [id], onDelete: Cascade)
}

enum CampaignRole {
  player
  co_gm
}

model CampaignMember {
  campaignId String
  userId     String
  role       CampaignRole @default(player)
  characterName String?
  joinedAt   DateTime     @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([campaignId, userId])
  @@index([userId])
}

enum CampaignSessionStatus {
  planned
  live
  completed
  cancelled
}

model CampaignSession {
  id              String                @id
  campaignId      String
  serverId        String
  title           String
  description     String?
  scheduledStart  DateTime?
  scheduledEnd    DateTime?
  voiceChannelId  String?
  textChannelId   String?
  status          CampaignSessionStatus @default(planned)
  agenda          String?
  recap           String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  campaign     Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  voiceChannel Channel?  @relation("SessionVoiceChannel", fields: [voiceChannelId], references: [id], onDelete: SetNull)
  textChannel  Channel?  @relation("SessionTextChannel", fields: [textChannelId], references: [id], onDelete: SetNull)
  rsvps        CampaignSessionRsvp[]
  /// Wave 3 #48 — AI-generated recaps for this session.
  recaps       SessionRecap[]            @relation("SessionRecaps")

  @@index([campaignId, scheduledStart])
}

enum RsvpStatus {
  yes
  no
  maybe
  late
}

model CampaignSessionRsvp {
  sessionId  String
  userId     String
  status     RsvpStatus @default(maybe)
  updatedAt  DateTime   @updatedAt

  session CampaignSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionId, userId])
