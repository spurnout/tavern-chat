# =============================================================================
# Tavern .env example
# Copy to .env and fill in. NEVER commit a real .env.
#
# DEFAULTS ARE TUNED FOR NO-DOCKER LOCAL DEV. The only external service you
# need is Postgres. Everything else (Redis, S3 / object storage, ClamAV,
# LiveKit) is optional — Tavern falls back to in-process / on-disk
# equivalents when the corresponding env vars are blank.
# =============================================================================

APP_NAME=Tavern
NODE_ENV=development

# ---- API server ------------------------------------------------------------
HOST=0.0.0.0
PORT=3001
PUBLIC_BASE_URL=http://localhost:3001
# Web dev server port. Defaults to 3030 (see CLAUDE.md for why), but a few
# scaffolds collide on 3000 — uncomment if you want to free it for them.
# WEB_PORT=3030

# Pino log level. trace|debug|info|warn|error|fatal. INF-010.
LOG_LEVEL=info

# Comma-separated list of allowed CORS origins for the frontend.
# 3030 is Tavern's web dev default; 3000 included for backwards compat / WEB_PORT overrides.
ALLOWED_ORIGINS=http://localhost:3030,http://localhost:3000

# ---- Auth ------------------------------------------------------------------
# Generate strong values with:  openssl rand -hex 48
JWT_ACCESS_SECRET=replace-me-with-48-bytes-of-hex-please-replace-me
JWT_REFRESH_SECRET=replace-me-with-48-different-bytes-of-hex-please-replace
# Separate key for the short-lived staged-TOTP token (between password and
# TOTP steps of login). Domain-separated from JWT_ACCESS_SECRET so a process
# that can mint access tokens can't also forge a staged token for arbitrary
# userIds (bypassing the password check). When blank, falls back to a
# derived value — set it explicitly in production. openssl rand -hex 48
STAGED_TOTP_SECRET=
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
ALLOW_PUBLIC_REGISTRATION=false

# ---- Mail / password reset (OPTIONAL) --------------------------------------
# Public URL of the web frontend. Used in outbound email links so users can
# click the reset link straight from their mailbox.
WEB_BASE_URL=http://localhost:3030
# SMTP. When SMTP_HOST is blank, outbound mail is logged to the API process
# stdout instead of dispatched — perfectly fine for dev, never for production.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# From-address on outbound mail. Defaults to `no-reply@<PUBLIC_BASE_URL host>`.
SMTP_FROM=
# Password-reset token lifetime, in seconds. Default 3600 (1 hour).
PASSWORD_RESET_TTL_SECONDS=3600

# ---- WebAuthn / passkeys (OPTIONAL) ----------------------------------------
# Relying-Party identifier — must be the registrable domain the user sees in
# the browser bar (NOT the URL). `localhost` is correct for dev. In
# production this MUST be your canonical host (e.g. `tavern.example.com`)
# AND the page must be served over HTTPS — WebAuthn refuses to register
# credentials otherwise. Mismatch between RP-ID and origin is exactly how
# the protocol defends against phishing, so the strictness is intentional.
WEBAUTHN_RP_ID=localhost
# Friendly name displayed by the user's authenticator. Defaults to APP_NAME.
WEBAUTHN_RP_NAME=
# Full origin (scheme + host + port) the browser sees. Defaults to WEB_BASE_URL.
WEBAUTHN_ORIGIN=

# ---- Postgres (REQUIRED) ---------------------------------------------------
# Native local install: a typical "postgres -U postgres -h localhost" setup.
#   1. createuser tavern --pwprompt    (use 'tavern-dev' for the dev password)
#   2. createdb tavern --owner=tavern
# Or use docker: pnpm docker:up   (see docs/docker-setup.md)
DATABASE_URL=postgresql://tavern:tavern-dev@localhost:5432/tavern

# ---- Redis (OPTIONAL) ------------------------------------------------------
# When unset: gateway pub/sub is in-process and the upload pipeline runs
# in-process (the worker process is a no-op).
# When set: BullMQ + Redis pub/sub for multi-replica deployments.
# Example: REDIS_URL=redis://localhost:6379
REDIS_URL=

# ---- Storage ---------------------------------------------------------------
# "local": files go to LOCAL_STORAGE_DIR, served by the API.
# "s3":    files go to an S3-compatible endpoint (Garage, AWS, R2, B2, etc.).
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=./data/storage

# Used only when STORAGE_BACKEND=s3.
S3_ENDPOINT=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=tavern-media
S3_QUARANTINE_BUCKET=tavern-quarantine
S3_USE_SSL=false

# ---- LiveKit (OPTIONAL) ----------------------------------------------------
# Voice/video routes return 503 when these are blank; the rest of the app
# works fine. To enable: install LiveKit (native binary or docker) and set
# matching values here and in infra/livekit/livekit.yaml.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ---- Trust & safety --------------------------------------------------------
TRUST_SAFETY_CORE_ENABLED=true
# When CLAMAV_HOST is blank, scanning is skipped. Default ALLOW_UNSCANNED_UPLOADS=false
# means those uploads are REJECTED — flip to true only when you knowingly
# accept unscanned uploads (typically dev). In production with ClamAV
# configured this stays false and the scanner enforces.
CLAMAV_HOST=
CLAMAV_PORT=3310
ALLOW_UNSCANNED_UPLOADS=false
BLOCK_EXECUTABLE_UPLOADS=true
BLOCK_ARCHIVE_UPLOADS=true
STRIP_IMAGE_METADATA=true
MAX_MESSAGE_LENGTH=4000

# ---- Worker process --------------------------------------------------------
# Used only when REDIS_URL is set (otherwise the worker exits immediately).
API_BASE_URL=http://localhost:3001

# ---- Seed (optional overrides for `pnpm db:seed`) --------------------------
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change-me-in-dev
SEED_INVITE_CODE=DEV-INVITE
SEED_SERVER_NAME=The Tavern

# ---- Postgres docker compose vars (used only by infra/docker/docker-compose.yml) ----
POSTGRES_USER=tavern
POSTGRES_PASSWORD=tavern-dev
POSTGRES_DB=tavern

# ---- Garage (used only by scripts/garage-config.mjs in non-dev mode) -------
# In NODE_ENV=development / test the script generates fresh random secrets on
# first run. In production the script REFUSES to fall back to dev values; set
# all three of these. Generate with:
#   node -e "const c=require('crypto'); console.log(c.randomBytes(32).toString('hex')); console.log(c.randomBytes(32).toString('base64')); console.log(c.randomBytes(32).toString('base64'));"
GARAGE_RPC_SECRET=
GARAGE_ADMIN_TOKEN=
GARAGE_METRICS_TOKEN=

# ---- Maintenance / retention (worker) --------------------------------------
# Days of AuditLogEntry history to retain (DB-009). Daily sweep deletes older.
AUDIT_RETENTION_DAYS=90
# Hours of Message.nonce retention (DB-010). Hourly sweep nulls older nonces
# so the partial-unique index doesn't permanently block retries.
NONCE_RETENTION_HOURS=24

# ---- Upload limits ---------------------------------------------------------
# Single source of truth for the maximum upload size (INF-017). Applied to
# the local-uploads route bodyLimit and the validator's generic-file cap.
# If running behind nginx, set `client_max_body_size` in nginx.conf to match.
UPLOAD_MAX_BYTES=104857600

# S3 presigned-PUT URL expiry, in seconds (STO-005).
S3_PRESIGN_EXPIRY_SECONDS=600
# Trust X-Forwarded-* headers from a reverse proxy (SEC-017). Auto-true in
# production, auto-false in dev/test. Override here only if you're sure.
# TRUST_PROXY=false

# ---- AI / LLM (OPTIONAL) ---------------------------------------------------
# Wave 3 #48 — operator-configured OpenAI-compatible endpoint for AI session
# recaps. Set to a Chat Completions URL. Examples:
#   OpenAI:    https://api.openai.com/v1
#   Ollama:    http://localhost:11434/v1   (then `ollama pull llama3.2:3b`)
#   llama.cpp: http://localhost:8080/v1
#   LM Studio: http://localhost:1234/v1
# When blank, /api/campaigns/:id/recaps returns 503 with a clear message and
# the UI hides the "Generate recap" button.
LLM_ENDPOINT=
LLM_API_KEY=
# Model identifier sent in the request body. Default suits OpenAI; for Ollama
# use the local tag (e.g. llama3.2:3b).
LLM_MODEL=gpt-4o-mini

# ---- OIDC / SSO (OPTIONAL) -------------------------------------------------
# Wave 3 #36 — OpenID Connect single sign-on. When OIDC_ISSUER_URL is set,
# Tavern fetches /.well-known/openid-configuration from it on boot, exposes a
# "Sign in with SSO" button on /login, and accepts callbacks at
# /api/auth/sso/callback. Register that callback URL with your IdP.
# Tested-against: Keycloak, Authentik, Auth0, Microsoft Entra, Google.
# SAML deferred — OIDC covers modern IdPs and the enterprise tier can wait.
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Where the IdP redirects after auth. Defaults to <PUBLIC_BASE_URL>/api/auth/sso/callback.
OIDC_REDIRECT_URI=
# Label shown on the login button.
OIDC_BUTTON_LABEL=Sign in with SSO
# When true (default), an SSO sign-in whose (issuer, subject) doesn't match
# any local user is auto-linked to an existing account if the IdP returns a
# verified email that matches. Set to false for multi-IdP deployments where
# this is account-takeover-shaped (a victim with a known email can be
# silently linked by any new IdP the operator wires in).
OIDC_AUTO_LINK_BY_EMAIL=true

# ---- Federation (OPTIONAL) -------------------------------------------------
# Opt-in federation between Tavern instances. When false (the default), the
# instance runs purely standalone — no peering handshake, no outbound
# envelopes, no inbound /_federation endpoint. Phases 1–6 are implemented
# (peering, remote-user identity, channel messages, invites + Tavern mirror,
# 1:1 DMs gated by the `dms` capability, presence gated by the `presence`
# capability + FEDERATION_PRESENCE_ENABLED). Voice is local-only.
FEDERATION_ENABLED=false
FEDERATION_PRESENCE_ENABLED=false

# REQUIRED when FEDERATION_ENABLED=true in production. AES-256-GCM key used
# to encrypt per-server FederationKey.privateKey and per-user
# User.federationKeyPrivate at rest. Same key MUST be set on the worker
# (which decrypts both to sign outbound envelopes). 32 raw bytes,
# base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TAVERN_DATA_KEY=
