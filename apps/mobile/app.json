{
  "expo": {
    "name": "Tavern",
    "slug": "tavern-mobile",
    "version": "0.1.0",
    "scheme": "tavern",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "app.tavern.mobile",
      "permissions": ["INTERNET"]
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
